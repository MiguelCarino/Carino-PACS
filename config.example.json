{
  "scp": {
    "aet": "CARINOPACS",
    "bind": "0.0.0.0",
    "port": 11112,
    "storage_dir": "./received",
    "organize": true,
    "min_free_gb": 2,
    "allowed_aets": [],
    "tls": false,
    "tls_cert": "",
    "tls_key": "",
    "tls_ca": ""
  },
  "scu": {
    "aet": "CARINOSCU",
    "watch_dir": "./outgoing",
    "poll_interval": 3,
    "on_success": "keep",
    "sent_dir": "./sent",
    "pending_dir": "./pending",
    "tls_verify": true,
    "tls_ca": "",
    "tls_cert": "",
    "tls_key": ""
  },
  "print": {
    "enabled": false,
    "aet": "CARINOPRINT",
    "bind": "0.0.0.0",
    "port": 11113,
    "color": false,
    "layout": "pdf",
    "allowed_aets": [],
    "tls": false,
    "tls_cert": "",
    "tls_key": ""
  },
  "mwl": {
    "enabled": false,
    "aet": "CARINOMWL",
    "bind": "0.0.0.0",
    "port": 11114,
    "allowed_aets": [],
    "tls": false,
    "tls_cert": "",
    "tls_key": ""
  },
  "ris": {
    "enabled": false,
    "bind": "0.0.0.0",
    "port": 2575,
    "store_dir": "./ris",
    "match_on": "accession",
    "auto_close": true,
    "allowed_hosts": []
  },
  "emergency": {
    "armed": false,
    "probe_interval_sec": 30,
    "offline_threshold_sec": 120,
    "recovery_successes": 2,
    "auto_activate": false,
    "hold_and_forward": true
  },
  "destinations": [
    {
      "name": "Example PACS",
      "host": "127.0.0.1",
      "port": 104,
      "aet": "REMOTEPACS",
      "enabled": false,
      "tls": false,
      "no_ris": false,
      "emergency_trigger": false
    }
  ],
  "web": {
    "host": "127.0.0.1",
    "port": 8042,
    "editor_url": "/editor/"
  },
  "logs_dir": "./logs"
}
