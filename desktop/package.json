{
  "name": "carino-pacs-desktop",
  "productName": "Carino PACS",
  "version": "1.1.0",
  "description": "Tray agent + desktop window for the Carino PACS DICOM store server",
  "author": { "name": "Miguel Carino", "email": "hello@carino.systems" },
  "homepage": "https://github.com/MiguelCarino/Carino-PACS",
  "license": "AGPL-3.0-or-later",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "systems.carino.pacs",
    "productName": "Carino-PACS",
    "afterSign": "build/notarize.js",
    "beforeBuild": "build/before-build.js",
    "files": ["main.js", "loading.html", "assets/**/*"],
    "extraResources": [
      { "from": "engine", "to": "engine" }
    ],
    "mac": {
      "category": "public.app-category.medical",
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "rpm", "deb"],
      "category": "Utility",
      "maintainer": "Carino Systems <hello@carino.systems>",
      "synopsis": "Simple DICOM store PACS — receive and auto-forward medical images",
      "icon": "build/icons",
      "executableName": "carino-pacs",
      "desktop": { "Name": "Carino PACS" }
    }
  }
}
